{
  "name": "broken-image-reporter",
  "version": "0.1.0",
  "description": "Detect every broken <img> on the page, recover its HTTP status, and report it. Zero dependencies, framework-agnostic, with an optional React hook.",
  "keywords": [
    "image",
    "broken-image",
    "onerror",
    "monitoring",
    "devtools",
    "react"
  ],
  "license": "MIT",
  "author": "Dev-BestOW",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Dev-BestOW/broken-image-reporter.git"
  },
  "homepage": "https://github.com/Dev-BestOW/broken-image-reporter#readme",
  "bugs": {
    "url": "https://github.com/Dev-BestOW/broken-image-reporter/issues"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./react": {
      "import": {
        "types": "./dist/react.d.ts",
        "default": "./dist/react.js"
      },
      "require": {
        "types": "./dist/react.d.cts",
        "default": "./dist/react.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "react": [
        "./dist/react.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup src/index.ts src/react.ts --format esm,cjs --dts --clean --splitting",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepack": "npm run build",
    "prepublishOnly": "npm run typecheck && npm test"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.10",
    "jsdom": "^29.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.2.7",
    "tsup": "^8.3.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "publishConfig": {
    "access": "public"
  }
}
